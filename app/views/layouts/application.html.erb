<!DOCTYPE html>
<html>
  <head>
    <title>
      <%= content_for(:title) || "Pragprog Books Online Store" %>
    </title>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in
        config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="bg-green-700 flex items-center justify-between px-4">
      <div class="flex items-center gap-4">
        <%= image_tag 'logo.svg', alt: 'The Pragmatic Bookshelf' %>

        <h1>
          <%= @page_title %>
        </h1>
      </div>

      <div>
        <%= form_with url: store_index_path, method: :get,
              data: { controller: "locale" }, class: "flex items-center gap-2" do %>
          <%= select_tag "set_locale",
                options_for_select(LANGUAGES, I18n.locale),
                class: "rounded-md border border-gray-300 px-2 py-1 text-sm",
                data: { action: "change->locale#submit" } %>
          <%= submit_tag "Change", data: { locale_target: "submit" },
                class: "rounded-md bg-white/90 px-2 py-1 text-sm" %>
        <% end %>
      </div>
    </header>

    <section class="flex">
      <nav class="bg-green-900 p-6">
        <%= render partial: 'layouts/cart', locals: { cart: @cart } %>

        <ul class="text-gray-300 leading-8">
          <li>
            <%= link_to t('.home'), store_index_path %>
          </li>
          <li>
            <%= link_to t('.questions'), questions_path %>
          </li>
          <li>
            <%= link_to t('.news'), news_path %>
          </li>
          <li>
            <%= link_to t('.contact'), contact_path %>
          </li>
        </ul>

        <hr class="my-2">

        <ul class="text-gray-300 leading-8">
          <% if authenticated? %>
            <li>
              <%= link_to 'Orders', orders_path(locale: I18n.locale) %>
            </li>
            <li>
              <%= link_to 'Products', products_path(locale: I18n.locale) %>
            </li>
            <li>
              <%= link_to 'Users', users_path(locale: I18n.locale) %>
            </li>
            <li>
              <%= button_to 'Logout', session_path(locale: I18n.locale), method: :delete %>
            </li>
          <% else %>
            <li>
              <%= link_to 'Login', new_session_path(locale: I18n.locale) %>
            </li>
          <% end %>
        </ul>
      </nav>

      <main class="container mx-auto mt-4 px-5 flex">
        <%= yield %>
      </main>
    </section>
  </body>
</html>
